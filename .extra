# Git credentials
# Not in the repository, to prevent people from accidentally committing under my name
GIT_AUTHOR_NAME="Yudi Purwanto"
GIT_COMMITTER_NAME="$GIT_AUTHOR_NAME"
git config --global user.name "$GIT_AUTHOR_NAME"
GIT_AUTHOR_EMAIL="purwantoyudi42@gmail.com"
GIT_COMMITTER_EMAIL="$GIT_AUTHOR_EMAIL"
git config --global user.email "$GIT_AUTHOR_EMAIL"
GIT_PAGER_DIFF = "diff-so-fancy | less --tabs=4 -RFX"
GIT_PAGER_SHOW = "diff-so-fancy | less --tabs=4 -RFX"
git config --global pager.diff "$GIT_PAGER_DIFF"
git config --global pager.show "$GIT_PAGER_SHOW"
